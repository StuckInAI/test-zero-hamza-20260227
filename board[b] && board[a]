import { checkWinner, isBoardFull } from './gameLogic';
import { Player } from '@/types/game';

describe('gameLogic', () => {
  describe('checkWinner', () => {
    it('should return null for empty board', () => {
      const board = Array(9).fill(null);
      expect(checkWinner(board)).toBeNull();
    });

    it('should detect horizontal win', () => {
      const board = [
        Player.X, Player.X, Player.X,
        null, null, null,
        null, null, null
      ];
      expect(checkWinner(board)).toBe(Player.X);
    });

    it('should detect vertical win', () => {
      const board = [
        Player.O, null, null,
        Player.O, null, null,
        Player.O, null, null
      ];
      expect(checkWinner(board)).toBe(Player.O);
    });

    it('should detect diagonal win', () => {
      const board = [
        Player.X, null, null,
        null, Player.X, null,
        null, null, Player.X
      ];
      expect(checkWinner(board)).toBe(Player.X);
    });

    it('should detect anti-diagonal win', () => {
      const board = [
        null, null, Player.O,
        null, Player.O, null,
        Player.O, null, null
      ];
      expect(checkWinner(board)).toBe(Player.O);
    });

    it('should return null for no winner', () => {
      const board = [
        Player.X, Player.O, Player.X,
        Player.X, Player.O, Player.O,
        Player.O, Player.X, Player.X
      ];
      expect(checkWinner(board)).toBeNull();
    });
  });

  describe('isBoardFull', () => {
    it('should return true for full board', () => {
      const board = Array(9).fill(Player.X);
      expect(isBoardFull(board)).toBe(true);
    });

    it('should return false for empty board', () => {
      const board = Array(9).fill(null);
      expect(isBoardFull(board)).toBe(false);
    });

    it('should return false for partially filled board', () => {
      const board = [
        Player.X, null, Player.O,
        null, Player.X, null,
        Player.O, null, null
      ];
      expect(isBoardFull(board)).toBe(false);
    });
  });
});

